# Render sets PORT automatically — don't change this
# PORT=10000

# Set to "production" on Render
FLASK_ENV=production

# Async mode — use "eventlet" on Render, "threading" locally
ASYNC_MODE=eventlet

# Your AI API keys (add these in Render Dashboard → Environment)
GEMINI_KEY="your-gemini-api-key"
OPENAI_API_KEY="your-openai-api-key"
